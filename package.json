{
  "name": "coupang-bot",
  "version": "1.2.3",
  "main": "dist/main.js",
  "scripts": {
    "clean": "node -e \"const fs = require('fs'); fs.rmSync('dist', { recursive: true, force: true });\"",
    "build": "tsc",
    "pack": "npm run clean && npm run build && electron-builder --win --x64",
    "start": "npm run build && electron .",
    "test": "jest"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "patchright": "^1.58.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "com.coupang.bot",
    "productName": "Coupang Bot",
    "artifactName": "Coupang-Bot-Setup-${version}.${ext}",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "snowing152",
        "repo": "commerce-bot"
      }
    ],
    "compression": "maximum",
    "files": [
      "dist/**/*",
      "config/**/*",
      "src/index.html"
    ]
  }
}
